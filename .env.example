# Super Agent runtime paths
# These are optional. If unset, Electron uses its normal app userData directory.
SUPER_AGENT_DB_PATH=./super-agent-data/super-agent.sqlite
SUPER_AGENT_WORKSPACE_DIR=./super-agent-data/workspace

# Test provider. Leave empty in normal dev.
# Set to "stub" only when intentionally testing without real providers.
SUPER_AGENT_TEST_PROVIDER=

# Optional YAML config override for MCP servers. Defaults to ~/.super-agent/config.yaml, then app userData config.yaml.
SUPER_AGENT_CONFIG_PATH=

