{
  "name": "super-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Super Agent desktop AI agent MVP with a controllable browser workspace.",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "node scripts/ensure-electron.mjs",
    "prepare:electron": "node scripts/ensure-electron.mjs",
    "dev": "node scripts/dev.mjs",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:regression",
    "test:unit": "vitest run --config vitest.config.ts tests/unit tests/ui",
    "test:integration": "vitest run --config vitest.config.ts tests/integration",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:regression": "vitest run --config vitest.config.ts tests/regression",
    "verify": "node scripts/verify.mjs"
  },
  "dependencies": {
    "@langchain/core": "^1.1.46",
    "@langchain/langgraph": "^1.3.0",
    "dotenv": "^17.4.2",
    "playwright-core": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sql.js": "^1.14.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^42.0.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.3.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "@langchain/langgraph": {
      "uuid": "^11.1.1",
      "@langchain/langgraph-sdk": {
        "uuid": "^13.0.0"
      }
    },
    "@langchain/langgraph-checkpoint": {
      "uuid": "^11.1.1"
    }
  }
}
